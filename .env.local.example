# Database — local Docker default (works with any connection string: Neon, Supabase, RDS)
#
# Three-role split (see docker/init-rls.sql for the full rationale):
#
#   - DATABASE_URL — runtime app connection. Self-host: `app_user` (no
#     BYPASSRLS). Prod (Neon): `app_user` (no BYPASSRLS). RLS policies fire on
#     every query — every protected `db.transaction` must go through
#     `withUserContext(ctx.userId, ...)` from `lib/db/rls.ts`.
#
#   - DATABASE_SERVICE_ROLE_URL — BYPASSRLS connection for the 4 documented
#     bypass call sites (reserve/release/diagnose invite-code,
#     clearOrgMembershipArtifacts) AND for the migration runner
#     (drizzle-kit push). Self-host: `service_role`. Prod (Neon):
#     `service_role`.
#
# Self-host bootstrap (fresh clone):
#   1. cp .env.local.example .env.local
#   2. Generate two passwords:
#        export APP_USER_PASSWORD=$(openssl rand -base64 24)
#        export SERVICE_ROLE_PASSWORD=$(openssl rand -base64 24)
#   3. Paste them into APP_USER_PASSWORD and SERVICE_ROLE_PASSWORD below.
#   4. Update DATABASE_URL and DATABASE_SERVICE_ROLE_URL with the same values.
#   5. bun run db:setup
#   6. bun run dev

APP_USER_PASSWORD=replace-with-openssl-rand-base64-24
SERVICE_ROLE_PASSWORD=replace-with-openssl-rand-base64-24

DATABASE_URL=postgresql://app_user:replace-with-openssl-rand-base64-24@localhost:5432/mymir
DATABASE_SERVICE_ROLE_URL=postgresql://service_role:replace-with-openssl-rand-base64-24@localhost:5432/mymir

# Better Auth (generate secret: openssl rand -base64 32)
BETTER_AUTH_SECRET=generate-a-random-secret-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3000

# For DEVELOPMENT ONLY - DO NOT USE IN PRODUCTION

# Database driver. Default (unset) uses `postgres-js` over TCP
# MYMIR_DB_DRIVER=driver-name
