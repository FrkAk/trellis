# Database — three-role split for RLS defense-in-depth.
#
# Self-host bootstrap:
#   1. cp .env.local.example .env.local
#   2. Generate three passwords:
#        export APP_USER_PASSWORD=$(openssl rand -base64 24)
#        export SERVICE_ROLE_PASSWORD=$(openssl rand -base64 24)
#        export AUTH_ROLE_PASSWORD=$(openssl rand -base64 24)
#   3. Paste them into the _PASSWORD vars below.
#   4. Update DATABASE_URL, DATABASE_SERVICE_ROLE_URL, DATABASE_AUTH_URL with the same values.
#   5. bun run db:setup
#   6. bun run dev

APP_USER_PASSWORD=replace-with-openssl-rand-base64-24
SERVICE_ROLE_PASSWORD=replace-with-openssl-rand-base64-24
AUTH_ROLE_PASSWORD=replace-with-openssl-rand-base64-24

# DATABASE_URL — runtime app connection. Role: app_user (NOBYPASSRLS).
# Every db.* call from lib/data/ must be wrapped in withUserContext(userId, ...).
DATABASE_URL=postgresql://app_user:replace-with-openssl-rand-base64-24@localhost:5432/mymir

# DATABASE_SERVICE_ROLE_URL — BYPASSRLS connection. Role: service_role.
# Used by drizzle-kit push (migrations) and the single documented bypass call
# site (lib/data/account.ts:clearOrgMembershipArtifacts).
DATABASE_SERVICE_ROLE_URL=postgresql://service_role:replace-with-openssl-rand-base64-24@localhost:5432/mymir

# DATABASE_AUTH_URL — Better Auth's connection. Role: auth_role (DML on
# neon_auth.*, no grants on public.*). Compromise of auth_role cannot read
# app data.
DATABASE_AUTH_URL=postgresql://auth_role:replace-with-openssl-rand-base64-24@localhost:5432/mymir

# Better Auth (generate secret: openssl rand -base64 32)
BETTER_AUTH_SECRET=generate-a-random-secret-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3000

# Database driver. Default (unset) uses postgres-js over TCP.
# MYMIR_DB_DRIVER=neon
