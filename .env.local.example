# Database — local Docker default (works with any connection string: Neon, Supabase, RDS)
DATABASE_URL=postgresql://mymir:mymir@localhost:5432/mymir

# Better Auth (generate secret: openssl rand -base64 32)
BETTER_AUTH_SECRET=generate-a-random-secret-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3000

# LLM Providers (configure at least one)
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key

# Optional providers
# ANTHROPIC_API_KEY=your-anthropic-key
# OPENAI_API_KEY=your-openai-key
# OLLAMA_BASE_URL=http://localhost:11434
