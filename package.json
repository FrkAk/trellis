{
  "name": "mymir",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "postbuild": "bun run scripts/postbuild.ts",
    "start": "node --env-file-if-exists=.env.local scripts/start.mjs",
    "test": "bun test",
    "test:db": "bun test tests/db tests/data tests/auth",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check:plugins": "bun run scripts/check-plugins.ts",
    "sync:plugins": "bun run scripts/check-plugins.ts --fix",
    "db:setup": "docker compose up -d --wait && docker exec -i mymir-db-1 psql -U mymir -d mymir < docker/init-auth.sql && bun run db:push",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@better-auth/oauth-provider": "^1.6.3",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@fontsource-variable/inter": "^5.2.8",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@neondatabase/serverless": "^1.0.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@tanstack/react-query": "^5.90",
    "@tanstack/react-query-devtools": "^5.90",
    "@types/d3-quadtree": "^3.0.6",
    "better-auth": "^1.6.1",
    "d3-force": "^3.0.0",
    "d3-quadtree": "^3.0.1",
    "drizzle-orm": "^0.45.2",
    "motion": "^12.38.0",
    "next": "^16.2.3",
    "postgres": "^3.4.8",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "server-only": "^0.0.1",
    "tailwindcss": "^4.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^10",
    "@types/d3-force": "^3.0.10",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "bun-types": "^1.3.13",
    "drizzle-kit": "^0.31.1",
    "eslint": "^9.28.0",
    "eslint-config-next": "^16.2.3",
    "eslint-plugin-import": "^2",
    "testcontainers": "^10",
    "typescript": "^6.0.2"
  }
}
