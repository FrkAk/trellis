{
  "name": "mymir",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "postbuild": "bun run scripts/postbuild.ts",
    "start": "node --env-file-if-exists=.env.local scripts/start.mjs",
    "pretest": "[ -n \"$TEST_DATABASE_URL\" ] || bun run db:test:up",
    "test": "bun test",
    "test:db": "bun test tests/db tests/data tests/auth",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check:plugins": "bun run scripts/check-plugins.ts",
    "sync:plugins": "bun run scripts/check-plugins.ts --fix",
    "db:setup": "docker compose --env-file .env.local up -d --wait && docker exec -i mymir-db-1 psql -U mymir -d mymir < docker/init-auth.sql && docker exec mymir-db-1 /docker-entrypoint-initdb.d/02-rls.sh && bun run db:push && docker exec -i mymir-db-1 psql -U mymir -d mymir < docker/grants.sql && docker exec -i mymir-db-1 psql -U mymir -d mymir < docker/rls-functions.sql && docker exec -i mymir-db-1 psql -U mymir -d mymir < docker/rls-policies.sql",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:test:up": "docker compose -f docker-compose.test.yml up -d --wait",
    "db:test:down": "docker compose -f docker-compose.test.yml down -v"
  },
  "dependencies": {
    "@better-auth/oauth-provider": "1.6.11",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@fontsource-variable/inter": "^5.2.8",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@neondatabase/serverless": "1.1.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-query-devtools": "^5.100.10",
    "@tanstack/react-virtual": "^3.13.24",
    "@types/d3-quadtree": "^3.0.6",
    "better-auth": "1.6.11",
    "d3-force": "^3.0.0",
    "d3-quadtree": "^3.0.1",
    "drizzle-orm": "0.45.2",
    "motion": "^12.38.0",
    "next": "^16.2.6",
    "postgres": "^3.4.9",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "server-only": "^0.0.1",
    "tailwindcss": "^4.3.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/d3-force": "^3.0.10",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "bun-types": "^1.3.14",
    "drizzle-kit": "0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "eslint-plugin-import": "^2.32.0",
    "typescript": "^6.0.3"
  }
}
